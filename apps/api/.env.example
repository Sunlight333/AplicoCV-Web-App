# ============================================================================
# AplicoCV Backend — Configuration / Key Registry
# ============================================================================
# Copy this file to `.env` and fill in only the keys you need. EVERYTHING is
# optional: with no .env at all, the API runs on safe defaults (SQLite, stubbed
# AI/billing/email, auto-generated encryption key).
#
# Each integration auto-activates the moment its key is present — no code change.
# Check what's live at any time:  GET /api/health  ->  {"integrations": {...}}
#
# After editing .env, restart the API:  systemctl restart aplicocv-api
# ============================================================================

# ---- Core ------------------------------------------------------------------
ENVIRONMENT=development                               # development | staging | production
DATABASE_URL=sqlite+aiosqlite:///./aplicocv.db        # or postgresql+asyncpg://user:pass@host/db

# ---- Auth (JWT) ------------------------------------------------------------
# Generate: python -c "import secrets; print(secrets.token_urlsafe(48))"
JWT_SECRET=dev-secret-change-me-in-production
ACCESS_TOKEN_MINUTES=15
REFRESH_TOKEN_DAYS=30

# ---- Credential encryption (Fernet) ---------------------------------------
# Required in production. Generate:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
FERNET_KEY=

# ---- AI / LLM --------------------------------------------------------------
# LLM_PROVIDER=auto picks OpenAI if OPENAI_API_KEY is set, else Anthropic if
# ANTHROPIC_API_KEY is set, else the offline stub. Just paste ONE key below.
LLM_PROVIDER=auto                                     # auto | stub | openai | anthropic
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6

# ---- Billing (Stripe) ------------------------------------------------------
# Without STRIPE_SECRET_KEY, checkout auto-upgrades the user (stub) so the flow
# is testable. Add the keys to use real Stripe Checkout + Customer Portal.
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_PRICE_ID=                                      # the Premium plan price id (price_...)
STRIPE_WEBHOOK_SECRET=                                # whsec_... for verifying webhooks

# ---- Google OAuth ----------------------------------------------------------
# Create credentials at https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=https://api.aplicocv.com/api/auth/google/callback

# ---- Document storage (S3 / Cloudflare R2) --------------------------------
# storage_provider=local keeps uploads on disk (UPLOAD_DIR). Set s3 or r2 +
# the credentials below to offload. For R2, also set S3_ENDPOINT_URL.
STORAGE_PROVIDER=local                                # local | s3 | r2
S3_BUCKET=
S3_REGION=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_ENDPOINT_URL=                                      # e.g. https://<acct>.r2.cloudflarestorage.com

# ---- Transactional email (Resend / SendGrid) ------------------------------
# email_provider=console just logs emails. Set resend or sendgrid + the key.
EMAIL_PROVIDER=console                                # console | resend | sendgrid
RESEND_API_KEY=
SENDGRID_API_KEY=
EMAIL_FROM=AplicoCV <no-reply@aplicocv.com>

# ---- Error monitoring (Sentry) --------------------------------------------
SENTRY_DSN=                                           # https://<key>@<org>.ingest.sentry.io/<id>

# ---- CORS / uploads --------------------------------------------------------
# CORS_ORIGINS is a JSON array. Add your frontend origins.
# CORS_ORIGINS=["https://aplicocv.com","https://www.aplicocv.com","http://localhost:5173"]
UPLOAD_DIR=./uploads
