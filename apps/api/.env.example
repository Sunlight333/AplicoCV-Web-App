# Copy to .env to override defaults. All optional — the API runs with none set.
ENVIRONMENT=development
DATABASE_URL=sqlite+aiosqlite:///./aplicocv.db
JWT_SECRET=dev-secret-change-me-in-production

# LLM: "stub" (default, no keys), "openai", or "anthropic"
LLM_PROVIDER=stub
# OPENAI_API_KEY=
# ANTHROPIC_API_KEY=

# Optional credential-encryption key (Fernet). Generate with:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# FERNET_KEY=

# Stripe (optional — stub mode auto-upgrades without it)
# STRIPE_SECRET_KEY=
