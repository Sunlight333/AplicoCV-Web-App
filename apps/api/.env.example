# ============================================================================
# AplicoCV Backend — Configuration / Key Registry
# ============================================================================
# Copy this file to `.env` and fill in only the keys you need. EVERYTHING is
# optional: with no .env at all, the API runs on safe defaults (SQLite, stubbed
# AI/billing/email, auto-generated encryption key).
#
# Each integration auto-activates the moment its key is present — no code change.
# Check what's live at any time:  GET /api/health  ->  {"integrations": {...}}
#
# After editing .env, restart the API:  systemctl restart aplicocv-api
# ============================================================================

# ---- Core ------------------------------------------------------------------
ENVIRONMENT=development                               # development | staging | production
DATABASE_URL=sqlite+aiosqlite:///./aplicocv.db        # or postgresql+asyncpg://user:pass@host/db
# Where the web app is served (OAuth + billing redirects return here).
FRONTEND_URL=http://localhost:5173                     # prod: https://aplicocv.com

# ---- Auth (JWT) ------------------------------------------------------------
# Generate: python -c "import secrets; print(secrets.token_urlsafe(48))"
JWT_SECRET=dev-secret-change-me-in-production
ACCESS_TOKEN_MINUTES=15
REFRESH_TOKEN_DAYS=30

# ---- Credential encryption (Fernet) ---------------------------------------
# Required in production. Generate:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
FERNET_KEY=

# ---- AI / LLM --------------------------------------------------------------
# LLM_PROVIDER=auto picks OpenAI if OPENAI_API_KEY is set, else Anthropic if
# ANTHROPIC_API_KEY is set, else the offline stub. Just paste ONE key below.
LLM_PROVIDER=auto                                     # auto | stub | openai | anthropic
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6

# ---- Billing (Stripe) ------------------------------------------------------
# Without STRIPE_SECRET_KEY, checkout auto-upgrades the user (stub) so the flow
# is testable. Add the keys to use real Stripe Checkout + Customer Portal.
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_PRICE_ID=                                      # the Premium plan price id (price_...)
STRIPE_WEBHOOK_SECRET=                                # whsec_... for verifying webhooks

# ---- Billing (MercadoPago — preferred for LATAM) ---------------------------
# With MERCADOPAGO_ACCESS_TOKEN set, checkout uses MercadoPago Checkout Pro and
# takes precedence over Stripe. Get credentials at
# https://www.mercadopago.com/developers > Your integrations > Credentials.
# Set the currency to your account's country currency (ARS, BRL, CLP, MXN, USD…).
MERCADOPAGO_ACCESS_TOKEN=                             # APP_USR-... (or TEST-... for sandbox)
MERCADOPAGO_PUBLIC_KEY=                               # APP_USR-... (public key, optional)
# Charge/display currency for the whole catalogue. Defaults to CLP (the pricing
# standard); prices are defined in CLP in app/pricing.py and converted to this
# currency automatically. Set to your MercadoPago country currency: CLP, ARS, BRL,
# MXN, COP, PEN, UYU, or USD. (Tune the FX rates in app/pricing.py.)
MERCADOPAGO_CURRENCY=CLP

# ---- Google OAuth ----------------------------------------------------------
# Create credentials at https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=https://api.aplicocv.com/api/auth/google/callback

# ---- Document storage (S3 / Cloudflare R2) --------------------------------
# storage_provider=local keeps uploads on disk (UPLOAD_DIR). Set s3 or r2 +
# the credentials below to offload.
#
# Cloudflare R2 example (from the R2 bucket's Settings → S3 API):
#   STORAGE_PROVIDER=r2
#   S3_BUCKET=aplicocv
#   S3_REGION=auto
#   S3_ENDPOINT_URL=https://<account-id>.r2.cloudflarestorage.com   # NO /bucket suffix
#   S3_ACCESS_KEY_ID / S3_SECRET_ACCESS_KEY come from an R2 API token
#   (R2 → Manage API Tokens → Create, with Object Read & Write on this bucket).
STORAGE_PROVIDER=local                                # local | s3 | r2
S3_BUCKET=
S3_REGION=                                            # R2: auto
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_ENDPOINT_URL=                                      # e.g. https://<acct>.r2.cloudflarestorage.com

# ---- Transactional email (Resend / SendGrid) ------------------------------
# email_provider=console just logs emails. Set resend or sendgrid + the key.
EMAIL_PROVIDER=console                                # console | resend | sendgrid
RESEND_API_KEY=
SENDGRID_API_KEY=
EMAIL_FROM=AplicoCV <no-reply@aplicocv.com>

# ---- Background tasks (Celery / Redis) ------------------------------------
# With REDIS_URL set, the Beta AI Job Agent runs on a Celery Beat schedule.
# Without it, scans run synchronously on demand via POST /agent/scan.
REDIS_URL=                                            # e.g. redis://redis:6379/0
AGENT_SCAN_INTERVAL_HOURS=6
AGENT_MATCH_THRESHOLD=65

# ---- Error monitoring (Sentry) --------------------------------------------
SENTRY_DSN=                                           # https://<key>@<org>.ingest.sentry.io/<id>

# ---- CORS / uploads --------------------------------------------------------
# CORS_ORIGINS is a JSON array. Add your frontend origins.
# CORS_ORIGINS=["https://aplicocv.com","https://www.aplicocv.com","http://localhost:5173"]
UPLOAD_DIR=./uploads
