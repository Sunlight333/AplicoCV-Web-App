# Production build config for the Vercel demo deploy.
# No backend is deployed yet (Phase 3), so the app runs in mock mode: the whole
# UI is fully clickable with in-memory data. Flip VITE_USE_MOCKS to false once a
# real FastAPI backend is live and set VITE_API_BASE_URL to its URL.
VITE_API_BASE_URL=/api
VITE_USE_MOCKS=true
VITE_GOOGLE_OAUTH_URL=/api/auth/google/login
