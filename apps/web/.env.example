# Base URL for the FastAPI backend (Phase 3). Leave as /api to use the Vite dev proxy.
VITE_API_BASE_URL=/api

# When true, the app serves all data from an in-memory mock so the UI is fully
# clickable without the backend. Set to false once Phase 3 is running.
VITE_USE_MOCKS=true

# Backend endpoint that begins the Google OAuth 2.0 redirect flow.
VITE_GOOGLE_OAUTH_URL=/api/auth/google/login
