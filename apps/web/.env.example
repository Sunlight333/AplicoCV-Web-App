# ============================================================================
# AplicoCV Web App — Configuration / Key Registry
# ============================================================================
# Copy to `.env.local` (gitignored) for dev overrides, or set these as build
# vars in your host (Vercel/Netlify) for production.
#
# Only VITE_-prefixed vars reach the browser bundle. Never put SECRET keys here
# — only PUBLISHABLE/CLIENT ids. All secrets live in apps/api/.env.
# ============================================================================

# ---- Backend connection ----------------------------------------------------
# "/api" uses same-origin (nginx proxy in prod, Vite proxy in dev). Or set a
# full URL like https://api.aplicocv.com/api.
VITE_API_BASE_URL=/api

# When true, the app serves in-memory mock data and never calls the backend.
# Set false to use the real API.
VITE_USE_MOCKS=false

# ---- Google OAuth (public) -------------------------------------------------
# Backend endpoint that starts the OAuth redirect flow.
VITE_GOOGLE_OAUTH_URL=/api/auth/google/login

# ---- Stripe (publishable key only — safe for the browser) -----------------
VITE_STRIPE_PUBLISHABLE_KEY=

# ---- Sentry (frontend DSN — public by design) -----------------------------
VITE_SENTRY_DSN=
