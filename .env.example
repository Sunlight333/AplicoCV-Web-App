# Root .env for docker-compose variable substitution. Copy to `.env` on the VPS.
# Application secrets/keys live separately in apps/api/.env (see its .env.example).

# PostgreSQL credentials (the compose stack creates this DB on first boot).
POSTGRES_USER=aplicocv
POSTGRES_PASSWORD=change-me-strong-password
POSTGRES_DB=aplicocv

# uvicorn worker processes for the api service (set ~= number of vCPUs).
UVICORN_WORKERS=4
